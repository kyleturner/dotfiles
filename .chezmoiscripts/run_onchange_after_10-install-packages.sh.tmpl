#!/bin/bash
# run_onchange_after_10-install-packages.sh.tmpl
# Re-runs only when Brewfile content changes (chezmoi hashes it below).
# Hash: {{ include "dot_config/homebrew/Brewfile" | sha256sum }}
set -euo pipefail

echo "→ [10] Installing Homebrew packages..."

# --no-lock CLI flag was removed by Homebrew without deprecation and broke scripts that
# relied on it — the env var is the stable equivalent.
export HOMEBREW_BUNDLE_NO_LOCK=1

# Migrate any pre-existing "linear-linear" cask to its renamed token "linear" before
# brew bundle runs. This is the documented, correct fix for a real, confirmed Homebrew
# cask rename (Brewfile now uses "linear" directly) — `brew migrate --cask` is the
# supported command for exactly this case, not a manual uninstall/reinstall. Safe to
# run even if linear-linear was never installed (no-ops with a clear message).
if brew list --cask linear-linear &> /dev/null; then
  echo "→ Migrating cask linear-linear → linear..."
  brew migrate --cask linear-linear || echo "⚠️  brew migrate failed — see brew bundle output below for details."
fi

brew bundle --file="{{ .chezmoi.homeDir }}/.config/homebrew/Brewfile"

# OrbStack self-updates; Homebrew tracks a stale version afterward and plain `brew upgrade`
# would attempt a downgrade. --greedy forces a check against the real latest version.
brew upgrade --greedy orbstack || true

if ! brew bundle check --file="{{ .chezmoi.homeDir }}/.config/homebrew/Brewfile" > /dev/null 2>&1; then
  echo "⚠️  brew bundle check reports missing packages after install. Run:"
  echo "    brew bundle check --file=\"{{ .chezmoi.homeDir }}/.config/homebrew/Brewfile\" --verbose"
  echo "    to see what's missing, then re-run this bootstrap."
else
  echo "✓ [10] All Homebrew packages confirmed installed."
fi

# brew bundle can leave /opt/homebrew/share group-writable (drwxrwxr-x), which
# causes zsh compinit to prompt on every new shell. Strip the group-write bit.
if [ -d /opt/homebrew/share ]; then
  chmod g-w /opt/homebrew/share
  echo "✓ [10] Fixed /opt/homebrew/share permissions (removed group-write for compinit)."
fi

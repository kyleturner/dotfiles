#!/bin/bash
# run_onchange_after_60-install-codebase-memory-mcp.sh.tmpl
# codebase-memory-mcp has no Homebrew formula — real, confirmed via the project's own
# open GitHub issue (DeusData/codebase-memory-mcp #491, "brew installation for macos?",
# filed June 2026, unresolved). Installed here via the project's own script instead.
# See runbook-guide.md Section 4.17 for full usage guidance.
#
# Runs after script 50 (secrets) so CBM_ALLOWED_ROOT (set in mise global config, resolved
# via the secrets/mise pipeline) is already in place before this tool is ever invoked.
set -euo pipefail

echo "→ [60] Installing codebase-memory-mcp..."

if command -v codebase-memory-mcp &> /dev/null; then
  echo "✓ [60] codebase-memory-mcp already installed, skipping download."
else
  curl -fsSL https://raw.githubusercontent.com/DeusData/codebase-memory-mcp/main/install.sh | bash
  echo "✓ [60] codebase-memory-mcp installed."
fi

# Always reconcile hook/MCP registration, even when the binary was already present —
# confirmed idempotent via `codebase-memory-mcp install --dry-run` (preserves existing
# indexes, just re-detects agents and rewrites hook/config wiring). Without this, a run
# that skips the download branch above never repairs drifted or reset Claude Code hook
# config (e.g. ~/.claude/settings.json getting reset by something else) — `chezmoi apply`
# alone wouldn't fix it, since only the binary's own `install` step manages those files.
codebase-memory-mcp install -y --force
echo "✓ [60] codebase-memory-mcp hooks/config reconciled."

echo "   Per-project activation is manual, by design — say \"index this project\" to"
echo "   Claude Code inside a project directory when you want it, or run"
echo "   \`mise run memory:index\` yourself. auto_index stays off (see runbook-guide.md"
echo "   Section 4.17) so CBM_ALLOWED_ROOT is deliberately checked per project rather"
echo "   than triggered automatically on first connection."

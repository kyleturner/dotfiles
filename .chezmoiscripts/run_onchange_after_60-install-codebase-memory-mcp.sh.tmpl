#!/bin/bash
# run_onchange_after_60-install-codebase-memory-mcp.sh.tmpl
# codebase-memory-mcp has no Homebrew formula — real, confirmed via the project's own
# open GitHub issue (DeusData/codebase-memory-mcp #491, "brew installation for macos?",
# filed June 2026, unresolved). Installed here via the project's own script instead.
# See ARCHIVE.md Section 4.17 for full usage guidance and security posture.
#
# Runs after script 50 (secrets) so CBM_ALLOWED_ROOT (set in mise global config, resolved
# via the secrets/mise pipeline) is already in place before this tool is ever invoked.
set -euo pipefail

echo "→ [60] Installing codebase-memory-mcp..."

if command -v codebase-memory-mcp &> /dev/null; then
  echo "✓ [60] codebase-memory-mcp already installed, skipping."
else
  curl -fsSL https://raw.githubusercontent.com/DeusData/codebase-memory-mcp/main/install.sh | bash
  echo "✓ [60] codebase-memory-mcp installed."
fi

echo "   Per-project activation is manual, by design — say \"index this project\" to"
echo "   Claude Code inside a project directory when you want it. auto_index stays off"
echo "   (see ARCHIVE.md Section 4.17) so CBM_ALLOWED_ROOT is deliberately checked per"
echo "   project rather than triggered automatically on first connection."

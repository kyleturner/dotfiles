#!/bin/bash
# run_onchange_after_50-resolve-secrets.sh.tmpl
# Re-runs only when the global secrets template changes.
# Hash: {{ include "dot_config/secrets/dot_env.global.tpl" | sha256sum }}
# Requires: 1Password sign-in completed in preflight (runbook Section 0).
#
# File flow -- CORRECTED after a real execution failure. chezmoi's dot_ prefix rule is
# literal: "dot_foo becomes .foo" (the whole leading token gets a literal dot prepended,
# not just part of it). dot_env.global.tpl therefore becomes .env.global.tpl -- WITH a
# leading dot -- not env.global.tpl as an earlier version of this script assumed. That
# wrong assumption caused a real "no such file or directory" failure on first execution.
#
#   dot_config/secrets/dot_env.global.tpl   (this repo, op:// references, no chezmoi
#                                             template syntax -- chezmoi copies it verbatim)
#     -> chezmoi apply ->
#   ~/.config/secrets/.env.global.tpl       (op inject template, on disk, safe -- still
#                                             just op:// references, not secrets -- note
#                                             the leading dot, confirmed against chezmoi's
#                                             own attribute reference)
#     -> op inject ->
#   ~/.config/secrets/.env.global           (RESOLVED secrets, gitignored, chmod 600 --
#                                             this is what mise's [env] _.file reads)
set -euo pipefail

echo "-> [50] Resolving global secrets via op inject..."

mkdir -p ~/.config/secrets

if ! op whoami > /dev/null 2>&1; then
  echo "WARNING: Not signed in to 1Password CLI. Run 'op signin' and re-run this bootstrap."
  exit 1
fi

TEMPLATE_PATH="{{ .chezmoi.homeDir }}/.config/secrets/.env.global.tpl"

if [ ! -f "$TEMPLATE_PATH" ]; then
  echo "ERROR: Expected secrets template not found at $TEMPLATE_PATH"
  echo "   This means chezmoi did not apply dot_config/secrets/dot_env.global.tpl as"
  echo "   expected. Run 'chezmoi apply -v' and check its output before re-running this"
  echo "   script -- do not proceed without this file, since op inject has nothing to read."
  exit 1
fi

op inject -i "$TEMPLATE_PATH" -o ~/.config/secrets/.env.global
chmod 600 ~/.config/secrets/.env.global

echo "OK [50] Global secrets resolved to ~/.config/secrets/.env.global (chmod 600)."
echo "   Per-project secrets (.env.local) are resolved on-demand per project -- not part"
echo "   of this global bootstrap step. See runbook 'Secrets for a new project'."

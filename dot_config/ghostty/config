# ~/.config/ghostty/config
# See macos-dev-workstation-ARCHIVE.md Section 4.2 and Section 14.6.
#
# NOTE: theme/font-size/window styling below are reasonable starting defaults, not a
# researched decision the way the rest of this stack is — adjust to taste. The two lines
# marked REQUIRED are actual standing decisions from the archive and should not be removed.

# REQUIRED — see Section 14.3 Callout #3 / Section 14.6. Without this, `ssh` + `tmux` to a
# remote host without Ghostty's terminfo entry breaks with "missing or unsuitable terminal:
# xterm-ghostty". ssh-env sets TERM=xterm-256color automatically for such hosts; ssh-terminfo
# installs Ghostty's terminfo on remote hosts when possible.
shell-integration-features = ssh-env,ssh-terminfo

# Font — Nerd Font already in the Brewfile (font-jetbrains-mono-nerd-font), needed for
# Starship prompt icons and tmux/zsh glyphs to render correctly.
font-family = JetBrainsMono Nerd Font
font-size = 14

# Starting defaults — adjust freely, not a researched decision.
# NOTE: Ghostty 1.2.0 renamed its bundled themes from lowercase-hyphenated
# (catppuccin-mocha) to title-case-spaced (Catppuccin Mocha) — a real breaking change
# in Ghostty itself, not a typo here. Run `ghostty +list-themes` to see current valid
# names if this breaks again in a future Ghostty release.
theme = Catppuccin Mocha
window-padding-x = 10
window-padding-y = 10
cursor-style = block
mouse-hide-while-typing = true

# NOTE: any keybind or startup command added here that would run a project-specific tool
# command must call `mise run <task>` (or `tmuxp load <project>`), never the underlying
# tool directly — see the standing rule in Section 4.3 / 14.6.

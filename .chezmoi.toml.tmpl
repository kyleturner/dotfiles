# .chezmoi.toml.tmpl
# chezmoi reads this at `chezmoi init` time to determine per-machine template data.
# Prompts are kept to exactly three (name, email, profile) per the standing rule in
# macos-dev-workstation-ARCHIVE.md Section 4.3 — everything else is either hardcoded
# (this is a single-machine setup, see Section 4 Callout #1) or resolved via op inject.

{{- $name := promptStringOnce . "name" "Full name" "Kyle Turner" -}}
{{- $email := promptStringOnce . "email" "Git email" -}}
{{- $profile := promptStringOnce . "profile" "Profile (personal/work)" "personal" -}}

{{/*
NOTE: the blank line + this comment block exist deliberately to guarantee a real
newline lands before [data] below. The three promptStringOnce lines above use
{{- ... -}} trim markers on both sides to avoid leaving stray blank lines in the
rendered chezmoi.toml -- but that trimming is aggressive: it strips ALL whitespace
back to the previous non-whitespace character, which previously ate the newline
between the last comment line and [data], gluing them onto one line. Since a `#`
comment in TOML runs to end-of-line, [data] silently became part of the comment
and was never actually parsed as a table header -- name/email/profile then landed
outside [data] entirely, causing "map has no entry for key name" in every template
that referenced .name / .email. This comment block, which itself doesn't use
trim markers, forces a hard newline boundary before [data] regardless of how the
prompt lines above are trimmed.
*/}}

[data]
    name         = {{ $name | quote }}
    email        = {{ $email | quote }}
    profile      = {{ $profile | quote }}
    projectsDir  = "{{ .chezmoi.homeDir }}/Projects"
    githubUser   = "kyleturner"
    opVault      = "Developer"
    # NOTE: named opVault, not vault -- "vault" collides with chezmoi's own reserved
    # top-level config key (used for HashiCorp Vault integration, vault.command), which
    # caused a real "decoding failed... 'vault' expected a map or struct" error on first
    # real-world run. This field isn't currently consumed by any template (the vault name
    # is hardcoded directly in op:// references elsewhere) -- it exists for future use.

[git]
    autoCommit = false
    autoPush   = false
    # Deliberately manual — see runbook Section 6. Dotfile changes get reviewed and
    # committed by hand, not auto-pushed to a public repo without a look first.

[edit]
    command = "cursor"
    args    = ["-w"]

[diff]
    exclude = ["scripts"]
    # chezmoi diff doesn't need to show the run_onchange_ script bodies every time —
    # keeps `chezmoi diff` output focused on actual file changes.

[user]
    name = {{ .name | quote }}
    email = {{ .email | quote }}

[init]
    defaultBranch = main

[pull]
    rebase = false

[core]
    excludesfile = ~/.gitignore_global
    editor = cursor -w

[credential]
    helper = osxkeychain

[diff]
    tool = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true

# 1Password SSH agent — see Section 4.11
[gpg "ssh"]
    program = /Applications/1Password.app/Contents/MacOS/op-ssh-sign
[commit]
    gpgsign = false

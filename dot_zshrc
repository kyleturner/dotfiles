#!/bin/zsh
# ~/.zshrc — see runbook-guide.md Section 4.3.
# Order matters: mise activation MUST come before anything that expects mise-managed
# tools on $PATH. Starship comes after plugins so it can reflect their state.

# --- tmux: fzf session picker on every new Ghostty tab ---
# If sessions exist, fzf lists them — pick one to attach, Esc to create a new one.
# No sessions yet → new session immediately. Guards: $TMUX prevents re-entry inside
# tmux; [ -t 0 ] skips non-interactive contexts (scripts, CI, ssh pipes).
if [ -z "$TMUX" ] && [ -t 0 ]; then
    if tmux list-sessions &>/dev/null 2>&1; then
        session=$(tmux list-sessions -F "#{session_name}" \
            | fzf --prompt="  session › " \
                  --header="enter: attach  ·  esc: new session" \
                  --exit-0)
        if [ -n "$session" ]; then
            exec tmux attach-session -t "$session"
        else
            exec tmux new-session
        fi
    else
        exec tmux new-session
    fi
fi

# --- opensessions: sessionizer search path for the tmux sidebar's "new session"
# popup (n/c inside the sidebar). Mirrors the tmux global environment set in
# tmux.conf so the value is also available to plain interactive shells and any
# script that shells out to sessionizer.sh directly (outside a tmux popup).
export SESSIONIZER_DIR="$HOME/Projects"
export SESSIONIZER_MAXDEPTH=3

# --- mise: single source of truth for runtimes + per-directory env vars ---
# Without this line, mise is installed but not hooked into the shell.
eval "$(mise activate zsh)"

# --- Homebrew shell plugins ---
# zsh-autosuggestions — fish-style inline completion
if [ -f "$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh" ]; then
  source "$(brew --prefix)/share/zsh-autosuggestions/zsh-autosuggestions.zsh"
fi

# zsh-fast-syntax-highlighting — must be sourced near the end of plugin loading
if [ -f "$(brew --prefix)/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh" ]; then
  source "$(brew --prefix)/share/zsh-fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"
fi

# zsh-completions — extended completion definitions
if type brew &>/dev/null; then
  FPATH="$(brew --prefix)/share/zsh-completions:${FPATH}"
  autoload -Uz compinit && compinit
fi

# fzf — fuzzy history/file search, key bindings + completion
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# zoxide — smart cd
eval "$(zoxide init zsh)"

# --- This project's own config ---
source ~/.config/zsh/aliases.zsh
source ~/.config/zsh/functions.zsh

# --- Starship prompt — last, so it can reflect everything above ---
eval "$(starship init zsh)"

# --- History ---
HISTSIZE=50000
SAVEHIST=50000
HISTFILE=~/.zsh_history
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
